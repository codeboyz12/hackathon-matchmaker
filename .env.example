# ── App ───────────────────────────────────────────────────────────────────────
ENV=development

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=secret
MONGO_DB=hackathon

# ── Redis ─────────────────────────────────────────────────────────────────────
